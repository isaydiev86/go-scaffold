package v1

import (
	"context"

	http_server "{{ .ModuleName }}/gen/http/{{ .ServiceName }}_v1/server"
	"{{ .ModuleName }}/internal/dto"
	"{{ .ModuleName }}/pkg/render"
)

func (h *Handlers) Close{{ .EntityName }}(ctx context.Context, request http_server.Close{{ .EntityName }}RequestObject,
) (http_server.Close{{ .EntityName }}ResponseObject, error) {
	input := dto.Close{{ .EntityName }}Input{
		ID: request.ID.String(),
	}

	err := h.usecase.Close{{ .EntityName }}(ctx, input)
	if err != nil {
		err = render.Error(ctx, err, "request failed")

		return http_server.Close{{ .EntityName }}400JSONResponse{Error: err.Error()}, nil
	}

	return http_server.Close{{ .EntityName }}204Response{}, nil
}
