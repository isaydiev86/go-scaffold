package kafka_consumer

import (
	"context"
	"errors"
	"io"
	"time"

	"github.com/rs/zerolog/log"
	"github.com/segmentio/kafka-go"

	"{{ .ModuleName }}/internal/usecase"
	"{{ .ModuleName }}/pkg/logger"
)

type Config struct {
	Addr  []string `envconfig:"KAFKA_CONSUMER_ADDR"  required:"true"`
	Topic string   `default:"{{ .ServiceName }}-events" envconfig:"KAFKA_CONSUMER_TOPIC"`
	Group string   `default:"{{ .ServiceName }}-group"  envconfig:"KAFKA_CONSUMER_GROUP"`
}

type Consumer struct {
	reader  *kafka.Reader
	usecase *usecase.UseCase
	stop    context.CancelFunc
	done    chan struct{}
}

func New(c Config, uc *usecase.UseCase) *Consumer {
	r := kafka.NewReader(kafka.ReaderConfig{
		Brokers:        c.Addr,
		Topic:          c.Topic,
		GroupID:        c.Group,
		ErrorLogger:    logger.ErrorLogger(),
		CommitInterval: 100 * time.Millisecond,
	})

	ctx, stop := context.WithCancel(context.Background())

	consumer := &Consumer{
		reader:  r,
		usecase: uc,
		stop:    stop,
		done:    make(chan struct{}),
	}

	go consumer.run(ctx)

	return consumer
}

func (c *Consumer) run(ctx context.Context) {
	log.Info().Msg("kafka consumer: started")

FOR:
	for {
		m, err := c.reader.FetchMessage(ctx)
		if err != nil {
			switch {
			case errors.Is(err, context.Canceled): // Close() was called
				break FOR
			case errors.Is(err, io.EOF): // reader was closed
				break FOR
			}

			log.Error().Err(err).Msg("kafka consumer: FetchMessage")

			continue
		}

		log.Info().Str("key", string(m.Key)).Msg("kafka consumer: message received")

		// Handle the message here, e.g. unmarshal m.Value and call a usecase method:
		// err = c.usecase.Handle{{ .EntityName }}Event(ctx, m.Value)

		// Commit the offset to the consumer group
		if err = c.reader.CommitMessages(ctx, m); err != nil {
			log.Error().Err(err).Msg("kafka consumer: CommitMessages")
		}
	}

	close(c.done)
}

func (c *Consumer) Close() {
	log.Info().Msg("kafka consumer: closing")

	c.stop()

	if err := c.reader.Close(); err != nil {
		log.Error().Err(err).Msg("kafka consumer: reader.Close")
	}

	<-c.done

	log.Info().Msg("kafka consumer: closed")
}
