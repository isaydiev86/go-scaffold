package redis

import (
	"context"
	"encoding/json"
	"errors"

	"github.com/google/uuid"
	"github.com/redis/go-redis/v9"
	"github.com/rs/zerolog/log"

	"{{ .ModuleName }}/internal/domain"
)

// Get{{ .EntityName }} returns the cached entity; ok == false means a cache miss.
// Errors are logged, not returned — the cache is best-effort.
func (r *Redis) Get{{ .EntityName }}(ctx context.Context, id uuid.UUID) (domain.{{ .EntityName }}, bool) {
	var e domain.{{ .EntityName }}

	data, err := r.redis.Get(ctx, cacheKey(id)).Bytes()
	if err != nil {
		if !errors.Is(err, redis.Nil) {
			log.Error().Err(err).Msg("redis: Get{{ .EntityName }}: r.redis.Get")
		}

		return e, false
	}

	err = json.Unmarshal(data, &e)
	if err != nil {
		log.Error().Err(err).Msg("redis: Get{{ .EntityName }}: json.Unmarshal")

		return e, false
	}

	return e, true
}
