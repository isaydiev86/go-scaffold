package postgres

import (
	"context"
	"errors"
	"fmt"

	"github.com/google/uuid"
	"github.com/jackc/pgx/v5"

	"{{ .ModuleName }}/internal/domain"
	"{{ .ModuleName }}/pkg/transaction"
)

func (p *Postgres) Close{{ .EntityName }}(ctx context.Context, id uuid.UUID) error {
	const sql = `UPDATE {{ .ServiceNameSQL }} SET status = 'closed', closed_at = NOW(), updated_at = NOW()
                     WHERE id = $1`

	txOrPool := transaction.TryExtractTX(ctx)

	_, err := txOrPool.Exec(ctx, sql, id)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return domain.ErrNotFound
		}

		return fmt.Errorf("txOrPool.Exec: %w", err)
	}

	return nil
}
