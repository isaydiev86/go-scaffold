package postgres

import (
	"context"
	"fmt"
	"strings"

	"{{ .ModuleName }}/internal/domain"
	"{{ .ModuleName }}/pkg/transaction"
)

func (p *Postgres) SaveOutboxKafka(ctx context.Context, events ...domain.Event) error {
	if len(events) == 0 {
		return nil
	}

	var sb strings.Builder

	sb.WriteString(`INSERT INTO outbox (topic, key, value) VALUES `)

	args := make([]any, 0, len(events)*3)

	for i, e := range events {
		if e.Topic == "" {
			return domain.ErrEmptyTopic
		}

		if i > 0 {
			sb.WriteString(", ")
		}

		fmt.Fprintf(&sb, "($%d, $%d, $%d)", i*3+1, i*3+2, i*3+3)

		args = append(args, e.Topic, e.Key, e.Value)
	}

	txOrPool := transaction.TryExtractTX(ctx)

	_, err := txOrPool.Exec(ctx, sb.String(), args...)
	if err != nil {
		return fmt.Errorf("txOrPool.Exec: %w", err)
	}

	return nil
}
