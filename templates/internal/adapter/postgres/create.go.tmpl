package postgres

import (
	"context"
	"fmt"

	"{{ .ModuleName }}/internal/domain"
	"{{ .ModuleName }}/pkg/transaction"
)

func (p *Postgres) Create{{ .EntityName }}(ctx context.Context, e domain.{{ .EntityName }}) error {
	const sql = `INSERT INTO {{ .ServiceNameSQL }} (id, name, amount, status)
                    VALUES ($1, $2, $3, $4)`

	args := []any{
		e.ID,
		e.Name,
		e.Amount,
		e.Status.String(),
	}

	txOrPool := transaction.TryExtractTX(ctx)

	_, err := txOrPool.Exec(ctx, sql, args...)
	if err != nil {
		return fmt.Errorf("txOrPool.Exec: %w", err)
	}

	return nil
}
