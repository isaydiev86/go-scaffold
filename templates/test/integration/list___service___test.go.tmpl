//go:build integration

package test

import (
	"testing"

	"github.com/stretchr/testify/suite"
)

type List{{ .EntityName }}sSuite struct {
	BaseSuite
}

func TestList{{ .EntityName }}s(t *testing.T) {
	suite.Run(t, new(List{{ .EntityName }}sSuite))
}

func (s *List{{ .EntityName }}sSuite) TestList_OK() {
	s.createEntity("Item 1", 10000)
	s.createEntity("Item 2", 20000)
	s.createEntity("Item 3", 30000)

	order := "asc"
	limit := 10
	offset := 0

	entities, err := s.api.Get{{ .EntityName }}s(ctx, "created_at", &order, &offset, &limit)
	s.NoError(err)
	s.GreaterOrEqual(len(entities), 3)
}

func (s *List{{ .EntityName }}sSuite) TestList_WithPagination() {
	for i := 0; i < 5; i++ {
		s.createEntity("Paginated Item", float64((i+1)*10000))
	}

	order := "desc"
	limit := 2
	offset := 0

	// Первая страница.
	page1, err := s.api.Get{{ .EntityName }}s(ctx, "created_at", &order, &offset, &limit)
	s.NoError(err)
	s.Equal(2, len(page1))

	// Вторая страница.
	offset = 2
	page2, err := s.api.Get{{ .EntityName }}s(ctx, "created_at", &order, &offset, &limit)
	s.NoError(err)
	s.Equal(2, len(page2))

	// Страницы не должны пересекаться.
	s.NotEqual(page1[0].ID, page2[0].ID)
}

func (s *List{{ .EntityName }}sSuite) TestList_SortByAmount() {
	s.createEntity("Sort A", 50000)
	s.createEntity("Sort B", 10000)
	s.createEntity("Sort C", 90000)

	order := "asc"
	limit := 100

	entities, err := s.api.Get{{ .EntityName }}s(ctx, "amount", &order, nil, &limit)
	s.NoError(err)
	s.GreaterOrEqual(len(entities), 3)

	// Проверяем сортировку по возрастанию.
	for i := 1; i < len(entities); i++ {
		s.LessOrEqual(entities[i-1].Amount, entities[i].Amount)
	}
}

func (s *List{{ .EntityName }}sSuite) TestList_InvalidSort_Error() {
	_, err := s.api.Get{{ .EntityName }}s(ctx, "invalid_field", nil, nil, nil)
	s.Error(err)
}
