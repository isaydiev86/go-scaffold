//go:build integration

package test

import (
	"testing"

	"github.com/google/uuid"
	"github.com/stretchr/testify/suite"
)

type Update{{ .EntityName }}Suite struct {
	BaseSuite
}

func TestUpdate{{ .EntityName }}(t *testing.T) {
	suite.Run(t, new(Update{{ .EntityName }}Suite))
}

// --- Update (PUT) ---

func (s *Update{{ .EntityName }}Suite) TestUpdate_Amount_OK() {
	createdID := s.createEntity("Update Test", 50000)

	newAmount := 75000.0

	err := s.api.Update{{ .EntityName }}(ctx, createdID, nil, &newAmount, uuid.New().String())
	s.NoError(err)

	// Проверяем, что обновилось.
	entity, err := s.api.Get{{ .EntityName }}(ctx, createdID)
	s.NoError(err)
	s.Equal(newAmount, entity.Amount)
}

func (s *Update{{ .EntityName }}Suite) TestUpdate_MultipleFields_OK() {
	createdID := s.createEntity("Multi Update", 50000)

	newName := "Updated Name"
	newAmount := 80000.0

	err := s.api.Update{{ .EntityName }}(ctx, createdID, &newName, &newAmount, uuid.New().String())
	s.NoError(err)

	// Проверяем.
	entity, err := s.api.Get{{ .EntityName }}(ctx, createdID)
	s.NoError(err)
	s.Equal(newName, entity.Name)
	s.Equal(newAmount, entity.Amount)
}

// --- UpdateStatus (PATCH) ---

func (s *Update{{ .EntityName }}Suite) TestUpdateStatus_OK() {
	createdID := s.createEntity("Status Test", 50000)

	err := s.api.Update{{ .EntityName }}Status(ctx, createdID, 2, uuid.New().String())
	s.NoError(err)

	// Проверяем.
	entity, err := s.api.Get{{ .EntityName }}(ctx, createdID)
	s.NoError(err)
	s.Equal(2, entity.Status) // Active
}

func (s *Update{{ .EntityName }}Suite) TestUpdateStatus_InvalidStatus_Error() {
	createdID := s.createEntity("Invalid Status", 50000)

	err := s.api.Update{{ .EntityName }}Status(ctx, createdID, 999, uuid.New().String())
	s.Error(err)
}
