//go:build integration

package test

import (
	"context"
	"database/sql"
	"sync"
	"time"

	"github.com/google/uuid"
	"github.com/rs/zerolog"
	"github.com/rs/zerolog/log"
	"github.com/stretchr/testify/require"
	"github.com/stretchr/testify/suite"

{{ if .WithKafkaProducer }}	"{{ .ModuleName }}/internal/adapter/kafka_producer"
{{ end }}	pgadapter "{{ .ModuleName }}/internal/adapter/postgres"
{{- if .WithRedis }}
	redisadapter "{{ .ModuleName }}/internal/adapter/redis"
{{- end }}
	httpcontroller "{{ .ModuleName }}/internal/controller/http"
	"{{ .ModuleName }}/internal/usecase"
	"{{ .ModuleName }}/pkg/httpserver"
	"{{ .ModuleName }}/pkg/{{ .ServiceName }}_client_gen"
	pgpool "{{ .ModuleName }}/pkg/postgres"
{{- if .WithRedis }}
	pkgredis "{{ .ModuleName }}/pkg/redis"
{{- end }}
	"{{ .ModuleName }}/pkg/router"
	"{{ .ModuleName }}/pkg/transaction"
)

// Prepare:  make up
// Run test: make integration-test

const testPort = "8080"

var (
	ctx       = context.Background()
	setupOnce sync.Once
)

// BaseSuite — общая база для всех интеграционных suite.
// Каждый файл создаёт свой Suite, встраивая BaseSuite.
type BaseSuite struct {
	suite.Suite
	*require.Assertions

	api *{{ .ServiceName }}_client_gen.Client
}

func (s *BaseSuite) SetupSuite() {
	s.Assertions = s.Require()

	setupOnce.Do(func() {
		s.ResetMigrations()

		log.Logger = zerolog.Nop()

		// Postgres
		pgPool, err := pgpool.New(ctx, pgpool.Config{
			Host:     "localhost",
			Port:     "5432",
			User:     "login",
			Password: "pass",
			DBName:   "postgres",
		})
		s.NoError(err)

		transaction.Init(pgPool)
{{ if .WithRedis }}
		// Redis
		redisClient, err := pkgredis.New(pkgredis.Config{
			Addr: "localhost:6379",
		})
		s.NoError(err)
{{ end }}
		// Adapters
		pgAdapter := pgadapter.New()
{{- if .WithRedis }}
		redisAdapter := redisadapter.New(redisClient)
{{- end }}
{{- if .WithKafkaProducer }}
		// Kafka producer (the connection is lazy — a broker is only needed when producing)
		kafkaProducer := kafka_producer.New(kafka_producer.Config{Addr: []string{"localhost:9094"}})
{{- end }}

		// UseCase
		uc := usecase.New(pgAdapter{{ if .WithRedis }}, redisAdapter{{ end }}{{ if .WithKafkaProducer }}, kafkaProducer{{ end }})

		// HTTP server
		r := router.New()
		httpcontroller.{{ .EntityName }}Router(r, uc)
		_ = httpserver.New(r, httpserver.Config{Port: testPort})

		time.Sleep(500 * time.Millisecond)
	})

	// API client
	var err error
	s.api, err = {{ .ServiceName }}_client_gen.New({{ .ServiceName }}_client_gen.Config{
		Host: "localhost",
		Port: testPort,
	})
	s.NoError(err)
}

// --- Create helper для переиспользования в тестах ---

func (s *BaseSuite) createEntity(name string, amount float64) uuid.UUID {
	id, err := s.api.Create{{ .EntityName }}(ctx, name, amount)
	s.NoError(err)

	return id
}

// --- DB helper ---

func (s *BaseSuite) openDB() *sql.DB {
	const dbURL = "postgres://login:pass@localhost:5432/postgres?sslmode=disable"

	db, err := sql.Open("postgres", dbURL)
	s.NoError(err)

	return db
}
